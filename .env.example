# ── Tracking API configuration ───────────────────────────────────────────────
# Copy this file to ".env" and adjust. All values are optional; sensible
# defaults let the app run with zero setup (demo data).

# Which data source to use:
#   auto      (default) → official if a key is set, else the public web endpoint,
#                          and ALWAYS falls back to demo data so the UI works.
#   mock      → always return realistic demo data (no network).
#   official  → only the official 17track API (requires SEVENTEENTRACK_API_KEY).
#   web       → only the public 17track HTTP endpoint (no key; usually blocked
#               by anti-bot, kept for completeness).
#   scrape    → REAL data, no key: drives a headless browser against
#               parcelsapp.com (600+ couriers) and captures the live tracking
#               JSON. No demo fallback by default (set SCRAPE_FALLBACK_MOCK=true
#               to enable). Requires Playwright + a SYSTEM browser (Edge/Chrome):
#               parcelsapp serves no data to bundled headless Chromium.
PROVIDER_MODE=scrape

# Free key from https://api.17track.net (Settings → Security → Access Key).
# Leave blank to run without an account.
SEVENTEENTRACK_API_KEY=

# Include the full upstream payload under result.raw (handy for debugging).
# (Never sent to clients regardless; this only controls building it internally.)
INCLUDE_RAW=false

# Interactive API docs (Swagger at /docs, ReDoc at /redoc, OpenAPI at
# /openapi.json). OFF by default so end users can't see the API surface.
# Set to true for local development.
ENABLE_DOCS=false

# Outbound HTTP timeout, seconds.
REQUEST_TIMEOUT=20

# Internal port the app server (uvicorn) listens on. Used by the systemd unit
# (deploy/trackbox.service) and proxied to by Nginx. Change this if the default
# port is taken on your server — and update proxy_pass in deploy/nginx.conf to
# match. (Has no effect when you pass --port to uvicorn manually.)
APP_PORT=8080

# ── scrape mode (PROVIDER_MODE=scrape) ───────────────────────────────────────
# Run the browser headless (false shows the window — useful for debugging).
SCRAPE_HEADLESS=true
# Max seconds for a single browser lookup (render + parcelsapp query + capture).
SCRAPE_TIMEOUT=45
# Browser channel: "msedge"/"chrome" use a SYSTEM browser (no download). IMPORTANT
# for parcelsapp: it serves NO data to bundled headless Chromium (detected via the
# sec-ch-ua "HeadlessChrome" brand), so a real channel is required. Keep "msedge"
# on Windows; on Linux install Edge/Chrome and set "msedge"/"chrome".
SCRAPE_BROWSER_CHANNEL=msedge
# Fall back to demo data when a scrape fails/blocks? Default false = real data
# or an honest "not found" — never fake data.
SCRAPE_FALLBACK_MOCK=false
# Outbound proxy for the browser. On a VPS a RESIDENTIAL proxy greatly improves
# reliability (parcelsapp may rate-limit or block datacenter IPs). Format:
#   http://user:pass@gateway:port   (URL-encode special chars in user/pass)
SCRAPE_PROXY=

# ── Captcha solver (optional, legacy) ────────────────────────────────────────
# Not used by the parcelsapp scrape provider (kept for the generic 2Captcha
# integration in app/providers/solver.py). Leave SOLVER_PROVIDER empty to disable.
SOLVER_PROVIDER=
SOLVER_API_KEY=
# Max seconds to wait for the solver to return a token.
SOLVER_TIMEOUT=180
